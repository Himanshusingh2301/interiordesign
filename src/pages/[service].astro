---
import type { GetStaticPaths } from "astro";
import Layout from "../layouts/Layout.astro";

import Navbar from "../sections/Navbar.astro";
import Hero from "../sections/Hero.astro";
import IntroSplit from "../sections/IntroSplit.astro";
import FeatureGrid from "../sections/FeatureGrid.astro";
import AboutWithForm from "../sections/AboutWithForm.astro";
import ServicesGridLinked from "../sections/ServicesGridLinked.astro";
import ComparisonTable from "../sections/ComparisonTable.astro";
import CtaBanner from "../sections/CtaBanner.astro";
import BenefitsList from "../sections/BenefitsList.astro";
import ProcessSteps from "../sections/ProcessSteps.astro";
import FaqAccordion from "../sections/FaqAccordion.astro";
import ContactCards from "../sections/ContactCards.astro";
import SiteFooter from "../sections/SiteFooter.astro";

import { servicePageSchema, type ServicePageContent } from "../content/schemas";

export const getStaticPaths = (() => {
  const modules = import.meta.glob<{ default: unknown }>(
    "../content/services/*.json",
    { eager: true },
  );

  return Object.entries(modules).map(([filePath, mod]) => {
    const slug = filePath.split("/").pop()!.replace(/\.json$/, "");
    const data = servicePageSchema.parse(mod.default);
    return { params: { service: slug }, props: { data } };
  });
}) satisfies GetStaticPaths;

interface Props {
  data: ServicePageContent;
}

const { data } = Astro.props as Props;
const { header, content, footer } = data;
---

<Layout
  title={data.meta.title}
  description={data.meta.description}
  canonical={data.meta.canonical}
  ogImage={data.meta.ogImage}
  noindex={data.meta.noindex}
  lang={data.meta.lang}
>
  {header.navbar && <Navbar {...header.navbar} />}

  <main>
    {content.hero && <Hero {...content.hero} />}
    {content.intro && <IntroSplit {...content.intro} />}
    {content.whyChooseUs && <FeatureGrid {...content.whyChooseUs} />}
    {content.about && <AboutWithForm {...content.about} />}
    {content.services && <ServicesGridLinked {...content.services} />}
    {content.proVsDiy && <ComparisonTable {...content.proVsDiy} />}
    {content.midCta && <CtaBanner {...content.midCta} />}
    {content.benefits && <BenefitsList {...content.benefits} />}
    {content.process && <ProcessSteps {...content.process} />}
    {content.faqs && <FaqAccordion {...content.faqs} />}
    {content.contacts && <ContactCards {...content.contacts} />}
  </main>

  {footer.siteFooter && <SiteFooter {...footer.siteFooter} />}
</Layout>
