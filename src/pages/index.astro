---
import Layout from "../layouts/Layout.astro";

import Navbar from "../sections/Navbar.astro";
import Hero from "../sections/Hero.astro";
import IntroSplit from "../sections/IntroSplit.astro";
import FeatureGrid from "../sections/FeatureGrid.astro";
import AboutWithForm from "../sections/AboutWithForm.astro";
import ServicesGridLinked from "../sections/ServicesGridLinked.astro";
import ComparisonTable from "../sections/ComparisonTable.astro";
import CtaBanner from "../sections/CtaBanner.astro";
import BenefitsList from "../sections/BenefitsList.astro";
import ProcessSteps from "../sections/ProcessSteps.astro";
import FaqAccordion from "../sections/FaqAccordion.astro";
import ContactCards from "../sections/ContactCards.astro";
import SiteFooter from "../sections/SiteFooter.astro";

import { homePageSchema } from "../content/schemas";
import homeData from "../content/pages/home.json";
import {
  faqPageSchema,
  localBusinessSchema,
} from "../lib/structured-data";

// Slots in home.json are optional overrides. Each section below always mounts;
// missing or partial slot data falls back to that section's built-in defaults.
const home = homePageSchema.parse(homeData);
const { header, content, footer } = home;

const siteUrl = (Astro.site ?? new URL("https://atlantaleakdetection.vercel.app/")).href;
const businessName = home.header.navbar?.logo?.primary ?? "Atlanta Leak Detection Pros";
const footerContact = footer.siteFooter?.contact;
const socialLinks =
  footer.siteFooter?.social?.map((s) => s.href).filter((href) => !!href) ?? [];

const jsonLd = [
  localBusinessSchema({
    name: businessName,
    url: siteUrl,
    description: home.meta.description,
    telephone: footerContact?.phone,
    email: footerContact?.email,
    addressLocality: "Atlanta",
    addressRegion: "GA",
    addressCountry: "US",
    areaServed: ["Atlanta, GA", "Metro Atlanta"],
    priceRange: "$$",
    sameAs: socialLinks,
    openingHours: ["Mo-Sa 08:00-18:00"],
  }),
  faqPageSchema(content.faqs?.items ?? []),
].filter((s): s is Record<string, unknown> => s !== null);
---

<Layout
  title={home.meta.title}
  description={home.meta.description}
  canonical={home.meta.canonical}
  ogImage={home.meta.ogImage}
  noindex={home.meta.noindex}
  lang={home.meta.lang}
  jsonLd={jsonLd}
>
  <Navbar {...(header.navbar ?? {})} />

  <main>
    <Hero            {...(content.hero ?? {})} />
    <IntroSplit      {...(content.intro ?? {})} />
    <FeatureGrid     {...(content.whyChooseUs ?? {})} />
    <AboutWithForm   {...(content.about ?? {})} />
    <ServicesGridLinked {...(content.services ?? {})} />
    <ComparisonTable {...(content.proVsDiy ?? {})} />
    <CtaBanner       {...(content.midCta ?? {})} />
    <BenefitsList    {...(content.benefits ?? {})} />
    <ProcessSteps    {...(content.process ?? {})} />
    <FaqAccordion    {...(content.faqs ?? {})} />
    <ContactCards    {...(content.contacts ?? {})} />
  </main>

  <SiteFooter {...(footer.siteFooter ?? {})} />
</Layout>
