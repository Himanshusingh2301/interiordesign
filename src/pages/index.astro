---
import Layout from "../layouts/Layout.astro";
import RevealScript from "../components/RevealScript.astro";
import InteriorNavbar from "../sections/InteriorNavbar.astro";
import Sec045 from "../sections/Sec045.astro";
import Sec046 from "../sections/Sec046.astro";
import { sec045ContentSchema } from "../content/schemas";
import sec045Data from "../data/sec045.json";
import { localBusinessSchema, serviceSchema } from "../lib/structured-data";
import { resolveSiteUrl } from "../lib/site-url";

const sec045 = sec045ContentSchema.parse(sec045Data);
const { meta, modernInteriorHero } = sec045;
const business = modernInteriorHero.business;

const siteUrl = resolveSiteUrl();
const pageUrl = `${siteUrl}/`;
const businessId = `${pageUrl.replace(/\/$/, "")}/#business`;

const jsonLd = [
  localBusinessSchema({
    name: business.name,
    url: pageUrl,
    description: meta.description,
    telephone: business.telephone,
    addressLocality: business.addressLocality,
    addressRegion: business.addressRegion,
    addressCountry: business.addressCountry,
    areaServed: business.areaServed,
    priceRange: business.priceRange,
    additionalTypes: ["HomeAndConstructionBusiness"],
    image: meta.ogImage ?? modernInteriorHero.images.main.src,
  }),
  serviceSchema({
    name: "Interior Design Services in Indore",
    description: modernInteriorHero.description,
    url: pageUrl,
    serviceType: "Interior Design",
    areaServed: business.areaServed,
    provider: {
      name: business.name,
      url: pageUrl,
      id: businessId,
    },
  }),
].filter((s): s is Record<string, unknown> => s !== null);
---

<Layout
  title={meta.title}
  description={meta.description}
  ogImage={meta.ogImage}
  jsonLd={jsonLd}
  preloadImage={modernInteriorHero.images.main.src}
>
  <InteriorNavbar />

  <main id="main-content">
    <Sec045 />
    <Sec046 />
  </main>

  <RevealScript />
</Layout>
