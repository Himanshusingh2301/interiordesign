---
import data from "../data/sec052.json";

const section = data.freeDeliverablesSection;
const descriptions = Array.isArray(section.description)
  ? section.description
  : [section.description];
---

<section class="relative overflow-hidden bg-[#f8f5ef] py-6 lg:py-10">

  <div class="absolute left-0 top-0 h-40 w-40 rounded-full bg-[#b68d40]/10 blur-3xl"></div>
  <div class="absolute bottom-0 right-0 h-40 w-40 rounded-full bg-[#b68d40]/10 blur-3xl"></div>

  <div class="relative mx-auto w-[92%] max-w-[1350px]">

    <!-- Header -->
    <div class="mb-5 lg:mb-6">

      <h2 class="text-center text-xl font-bold leading-snug text-[#2c221c] md:text-2xl lg:whitespace-nowrap lg:text-3xl">
        {section.title}
      </h2>

      <p class="mx-auto mt-3 max-w-5xl text-center text-sm leading-6 text-[#6b625d] md:text-[15px] md:leading-7 lg:max-w-6xl">
        {descriptions[0]}
      </p>

    </div>

    <!-- Main Content -->
    <div class="grid items-stretch gap-4 lg:grid-cols-[26%_74%] lg:gap-5">

      <!-- Left Image -->
      <div class="relative min-h-[220px] overflow-hidden rounded-[20px] shadow-lg lg:min-h-0 lg:self-stretch">

        <img
          src={section.image}
          alt={section.title}
          loading="lazy"
          class="h-full w-full object-cover lg:absolute lg:inset-0"
        />

        <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent"></div>

        <div class="absolute bottom-3 left-3 right-3">
          <div class="rounded-xl border border-white/20 bg-white/90 p-3 shadow-xl backdrop-blur-md">
            <p class="text-xs leading-5 text-[#6b625d]">
              Together, these normally cost ₹15,000–₹40,000 as paid design fees in Indore — you get them at zero cost, whether or not you hire us.
            </p>
          </div>
        </div>

      </div>

      <!-- Right Side -->
      <div class="grid gap-2.5 sm:grid-cols-2 lg:grid-cols-3 lg:gap-3">

        {section.items.map((item, index) => (
          <div
            class:list={[
              "group rounded-xl border border-[#e8dfd2] bg-white p-3 shadow-sm transition-all duration-300 hover:-translate-y-0.5 hover:border-[#b68d40] hover:shadow-md",
              index === 3 && "lg:col-start-1",
              index === 4 && "lg:col-start-2",
            ]}
          >

            <div class="mb-1.5 flex h-8 w-8 items-center justify-center rounded-full bg-[#b68d40]/10 text-xs font-bold text-[#b68d40]">
              {item.number}
            </div>

            <h3 class="mb-1 text-sm font-semibold text-[#2c221c]">
              {item.title}
            </h3>

            <p class="text-[13px] leading-5 text-[#6b625d]">
              {item.description}
            </p>

          </div>
        ))}

        <!-- Why Free -->
        <div class="flex flex-col justify-center px-1 py-2 sm:col-span-2 lg:col-span-1 lg:col-start-3 lg:px-2">
          <p class="text-[13px] leading-5 text-[#6b625d] md:text-sm md:leading-6">
            <span class="font-semibold text-[#2c221c]">Why free?</span> {section.whyFree.text}
          </p>

          <a
            href={section.whyFree.cta.href}
            class="mt-3 inline-flex w-fit items-center gap-2 rounded-full bg-[#b68d40] px-5 py-2.5 text-sm font-bold text-white shadow-[0_4px_16px_rgba(182,141,64,0.4)] transition-all duration-300 hover:scale-[1.03] hover:bg-[#2c221c] hover:shadow-[0_6px_20px_rgba(44,34,28,0.3)]"
          >
            {section.whyFree.cta.label}
            <span aria-hidden="true">→</span>
          </a>
        </div>

      </div>

    </div>

  </div>

</section>
