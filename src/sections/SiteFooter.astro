---
export interface Props {
  logo?: {
    secondary?: string;
    primary?: string;
    href?: string;
  };
  tagline?: string;
  social?: Array<{ label: string; href: string; bgClass: string }>;
  servicesLinks?: Array<{ label: string; href: string }>;
  legalLinks?: Array<{ label: string; href: string }>;
  contact?: {
    phone?: string;
    addressLines?: string[];
    email?: string;
  };
  disclosure?: { heading: string; body: string };
}

const {
  logo = {
    secondary: "OUTDOOR LIGHTING",
    primary: "WILMINGTON",
    href: "/",
  },
  tagline =
    "We make Wilmington homes shine safely using durable, coastal-ready materials. Our skilled partners treat your home like their own, ensuring clear communication and a beautiful yard you are proud to show off.",
  social = [
    {
      label: "Facebook",
      href: "https://www.facebook.com/",
      bgClass: "bg-[#1877F2] hover:bg-[#166fe5]",
    },
    {
      label: "X",
      href: "https://twitter.com/",
      bgClass: "bg-neutral-900 hover:bg-neutral-800",
    },
    {
      label: "Reddit",
      href: "https://www.reddit.com/",
      bgClass: "bg-[#FF4500] hover:bg-[#e63e00]",
    },
    {
      label: "Pinterest",
      href: "https://www.pinterest.com/",
      bgClass: "bg-[#E60023] hover:bg-[#cc001f]",
    },
  ],
  servicesLinks = [
    { label: "Landscape Lighting", href: "#services" },
    { label: "Deck and Patio Lighting", href: "#services" },
    { label: "Pathway & Walkway Lighting", href: "#services" },
    { label: "Architectural & Facade Lighting", href: "#services" },
    { label: "Outdoor Security Lighting", href: "#services" },
    { label: "Commercial Outdoor Lighting", href: "#services" },
    { label: "Outdoor Lighting Repair & Maintenance", href: "#services" },
    { label: "Holiday & Christmas Lighting", href: "#services" },
  ],
  legalLinks = [
    { label: "Home", href: "/" },
    { label: "About Us", href: "#about" },
    { label: "Contact Us", href: "#contact" },
    { label: "Disclaimer", href: "#" },
    { label: "Privacy Policy", href: "#" },
    { label: "Referral Marketing Disclosure", href: "#" },
    { label: "Terms and Conditions", href: "#" },
  ],
  contact = {
    phone: "(910) 218-9037",
    addressLines: ["305 Raleigh St # E Wilmington, NC 28412"],
    email: "contact@outdoorlightingwilmington.com",
  },
  disclosure = {
    heading: "Referral Marketing Disclosure",
    body: "Outdoor Lighting Wilmington is a free service connecting homeowners with local outdoor lighting contractors. All contractors are independent, and we do not guarantee their work. It is your responsibility to verify that the hired professional holds the necessary license and insurance.",
  },
} = Astro.props;

const telHref = contact.phone
  ? `tel:${contact.phone.replace(/[^\d+]/g, "")}`
  : undefined;
const mailHref = contact.email ? `mailto:${contact.email}` : undefined;
---

<footer class="border-t border-slate-200 bg-white text-slate-800">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-14 lg:py-16">
    <div class="grid grid-cols-1 gap-12 sm:grid-cols-2 lg:grid-cols-4 lg:gap-10">
      <div>
        <a
          href={logo.href ?? "/"}
          class="inline-flex items-center gap-3"
          aria-label={`${logo.secondary ?? ""} ${logo.primary ?? ""} — Home`.trim()}
        >
          <svg
            viewBox="0 0 40 40"
            xmlns="http://www.w3.org/2000/svg"
            class="h-12 w-12 shrink-0"
            aria-hidden="true"
          >
            <defs>
              <radialGradient id="footerLanternGlow" cx="50%" cy="45%" r="55%">
                <stop offset="0%" stop-color="#FDE68A"></stop>
                <stop offset="55%" stop-color="#F59E0B"></stop>
                <stop offset="100%" stop-color="#D97706"></stop>
              </radialGradient>
            </defs>
            <rect x="14" y="4" width="12" height="3" rx="0.5" fill="#292524"></rect>
            <rect x="18.5" y="7" width="3" height="2.5" fill="#292524"></rect>
            <path d="M11 11h18v17H11V11z" fill="#292524"></path>
            <rect x="13.5" y="13" width="13" height="13" rx="1" fill="url(#footerLanternGlow)"></rect>
            <rect x="12" y="28" width="16" height="2.5" rx="0.5" fill="#292524"></rect>
            <line x1="20" y1="30.5" x2="20" y2="35" stroke="#292524" stroke-width="2.5" stroke-linecap="round"></line>
            <rect x="16" y="35" width="8" height="2" rx="0.5" fill="#292524"></rect>
          </svg>
          <span class="flex flex-col leading-none gap-0.5 text-left">
            <span class="text-[10px] sm:text-[11px] font-normal tracking-[0.12em] text-slate-600 uppercase">
              {logo.secondary}
            </span>
            <span class="text-lg font-bold tracking-wide text-slate-900 uppercase">
              {logo.primary}
            </span>
          </span>
        </a>

        <p class="mt-5 text-sm leading-relaxed text-slate-600">
          {tagline}
        </p>

        <ul class="mt-6 flex flex-wrap gap-2" aria-label="Social media">
          {
            social.map((s) => (
              <li>
                <a
                  href={s.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class={`inline-flex h-9 w-9 items-center justify-center rounded-full text-xs font-bold text-white shadow-sm transition-colors ${s.bgClass}`}
                  aria-label={s.label}
                >
                  {s.label.slice(0, 1)}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <nav aria-labelledby="footer-services-heading">
        <h3 id="footer-services-heading" class="text-base font-bold text-slate-900">
          Our Services
        </h3>
        <ul class="mt-4 space-y-2.5">
          {
            servicesLinks.map((l) => (
              <li>
                <a
                  href={l.href}
                  class="text-sm text-slate-600 hover:text-slate-900 hover:underline underline-offset-2"
                >
                  {l.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <nav aria-labelledby="footer-legal-heading">
        <h3 id="footer-legal-heading" class="text-base font-bold text-slate-900">
          Legal Pages
        </h3>
        <ul class="mt-4 space-y-2.5">
          {
            legalLinks.map((l) => (
              <li>
                <a
                  href={l.href}
                  class="text-sm text-slate-600 hover:text-slate-900 hover:underline underline-offset-2"
                >
                  {l.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <div>
        <h3 class="text-base font-bold text-slate-900">Contact Us</h3>
        <address class="mt-4 not-italic text-sm leading-relaxed text-slate-600 space-y-3">
          {
            contact.phone && telHref && (
              <p class="flex items-start gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="mt-0.5 h-4 w-4 shrink-0 text-slate-500" aria-hidden="true">
                  <path fill-rule="evenodd" d="M2 3.5A1.5 1.5 0 0 1 3.5 2h1.148a1.5 1.5 0 0 1 1.465 1.175l.716 3.223a1.5 1.5 0 0 1-.43 1.402L5.27 8.962a11.04 11.04 0 0 0 5.768 5.769l1.162-1.13a1.5 1.5 0 0 1 1.402-.43l3.223.716A1.5 1.5 0 0 1 18 15.352V16.5a1.5 1.5 0 0 1-1.5 1.5H15c-7.18 0-13-5.82-13-13V3.5Z" clip-rule="evenodd" />
                </svg>
                <a href={telHref} class="text-slate-800 hover:underline">
                  {contact.phone}
                </a>
              </p>
            )
          }
          {
            contact.addressLines?.map((line) => (
              <p>{line}</p>
            ))
          }
          {
            contact.email && mailHref && (
              <p>
                <a href={mailHref} class="text-slate-800 hover:underline break-all">
                  {contact.email}
                </a>
              </p>
            )
          }
        </address>

        <h4 class="mt-8 text-base font-bold text-slate-900">
          {disclosure.heading}
        </h4>
        <p class="mt-2 text-xs leading-relaxed text-slate-500">
          {disclosure.body}
        </p>
      </div>
    </div>
  </div>

</footer>
