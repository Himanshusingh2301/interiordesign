---
export interface Props {
  heading?: string;
  intro?: string;
  columns?: 2 | 3 | 4;
  items?: Array<{
    title: string;
    description: string;
  }>;
}

const DEFAULT_ITEMS: NonNullable<Props["items"]> = [
  {
    title: "Coastal-Grade Lighting Fixtures",
    description:
      "We install marine-grade brass and solid copper outdoor lighting fixtures designed to withstand Wilmington’s salty coastal air, humidity, and changing weather conditions.",
  },
  {
    title: "Dark Sky & Turtle-Safe Systems",
    description:
      "Our lighting systems follow Wilmington’s dark sky and sea turtle compliance guidelines while still improving nighttime visibility, safety, and curb appeal.",
  },
  {
    title: "Low-Maintenance Outdoor Lighting",
    description:
      "We use waterproof connections, premium LED fixtures, and durable installation methods that reduce maintenance issues and improve long-term reliability.",
  },
  {
    title: "Experienced Lighting Professionals",
    description:
      "Our outdoor lighting specialists create custom lighting designs focused on beauty, security, energy efficiency, and long-lasting performance.",
  },
];

const {
  heading = "Why Choose Our Outdoor Lighting Company",
  intro = "Professional outdoor lighting solutions designed for Wilmington homes, coastal weather conditions, long-term durability, and beautiful nighttime curb appeal.",
  columns = 4,
  items = DEFAULT_ITEMS,
} = Astro.props;

const colClass: Record<number, string> = {
  2: "md:grid-cols-2",
  3: "md:grid-cols-2 xl:grid-cols-3",
  4: "md:grid-cols-2 xl:grid-cols-4",
};
---

<section
  class="relative overflow-hidden bg-white py-16 sm:py-20 lg:py-28"
  aria-labelledby="why-choose-heading"
>
  <!-- Background Decoration -->
  <div class="absolute inset-0 bg-gradient-to-b from-gray-50 to-white"></div>

  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    
    <!-- Header -->
    <div class="mx-auto max-w-4xl text-center">
     

      <h2
        id="why-choose-heading"
        class="mt-6 text-4xl font-bold tracking-tight text-gray-900 sm:text-5xl lg:text-6xl leading-tight"
      >
        {heading}
      </h2>

      {intro && (
        <p
          class="mx-auto mt-6 max-w-3xl text-lg leading-relaxed text-gray-600 sm:text-xl"
        >
          {intro}
        </p>
      )}
    </div>

    <!-- Grid -->
    <div
      class={`mt-16 grid gap-6 ${colClass[columns]}`}
    >
      {
        items.map((item, index) => (
          <article
            class="group relative flex h-full flex-col rounded-2xl border border-gray-200 bg-white p-8 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:border-blue-200 hover:shadow-xl"
          >
            <!-- Number -->
            <div
              class="mb-6 flex h-12 w-12 items-center justify-center rounded-xl bg-amber-50 text-lg font-bold text-amber-700 ring-1 ring-blue-100"
            >
              {(index + 1).toString().padStart(2, "0")}
            </div>

            <!-- Content -->
            <h3
              class="text-xl font-bold leading-snug text-gray-900"
            >
              {item.title}
            </h3>

            <p
              class="mt-4 text-base leading-relaxed text-gray-600"
            >
              {item.description}
            </p>

            <!-- Bottom Accent -->
            <div
              class="mt-6 h-1 w-16 rounded-full bg-amber-500 transition-all duration-300 group-hover:w-24"
            ></div>
          </article>
        ))
      }
    </div>
  </div>
</section>