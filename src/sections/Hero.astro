---
export interface Props {
  heading?: string;
  cta?: {
    label: string;
    href: string;
  };
  image?: {
    src: string;
    alt: string;
  };
}

const {
  heading = "Welcome",
  cta = {
    label: "Get in touch",
    href: "#contact",
  },
  image = {
    src: "https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?auto=format&fit=crop&w=1920&q=80",
    alt: "Modern home exterior",
  },
} = Astro.props;
---

<section class="relative w-full overflow-hidden bg-gray-900">
  <img
    src={image.src}
    alt={image.alt}
    width="1920"
    height="1080"
    fetchpriority="high"
    loading="eager"
    decoding="async"
    class="absolute inset-0 h-full w-full object-cover"
  />

  <div
    class="absolute inset-0 bg-gradient-to-r from-black/80 via-black/55 to-black/10"
    aria-hidden="true"
  >
  </div>

  <div
    class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-24 sm:py-32 lg:py-36"
  >
    <div class="max-w-2xl">
      <h1
        class="text-4xl sm:text-5xl lg:text-[3.5rem] font-extrabold leading-[1.1] tracking-tight text-white"
      >
        {heading}
      </h1>

      <a
        href={cta.href}
        class="mt-8 inline-flex items-center gap-2 rounded-md bg-brand px-6 py-3 text-base font-bold text-white shadow-md transition-colors hover:bg-brand-hover focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 20 20"
          fill="currentColor"
          class="h-4 w-4"
          aria-hidden="true"
        >
          <path
            fill-rule="evenodd"
            d="M2 3.5A1.5 1.5 0 0 1 3.5 2h1.148a1.5 1.5 0 0 1 1.465 1.175l.716 3.223a1.5 1.5 0 0 1-.43 1.402L5.27 8.962a11.04 11.04 0 0 0 5.768 5.769l1.162-1.13a1.5 1.5 0 0 1 1.402-.43l3.223.716A1.5 1.5 0 0 1 18 15.352V16.5a1.5 1.5 0 0 1-1.5 1.5H15c-7.18 0-13-5.82-13-13V3.5Z"
            clip-rule="evenodd"></path>
        </svg>
        <span>{cta.label}</span>
      </a>
    </div>
  </div>
</section>
