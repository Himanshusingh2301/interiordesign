---
import content from "../data/sec046.json";

const section = content.consultationBar;
---

<section class="relative overflow-hidden bg-[#2E1A0C] py-6">

  <!-- subtle glow overlay -->
  <div
    class="pointer-events-none absolute inset-0"
    style="background: radial-gradient(ellipse 80% 60% at 50% 50%, rgba(216,177,90,0.07) 0%, transparent 70%);"
    aria-hidden="true"
  ></div>

  <!-- top + bottom border lines -->
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-[#d8b15a]/35 to-transparent" aria-hidden="true"></div>
  <div class="absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-[#d8b15a]/20 to-transparent" aria-hidden="true"></div>

  <div class="relative z-10 mx-auto w-[92%] max-w-[1350px]">
    <div class="flex flex-col items-center gap-6 lg:flex-row lg:flex-nowrap lg:items-center lg:justify-between">

      <!-- LEFT — icon + text -->
      <div
        class="flex w-full shrink-0 items-center justify-center gap-4 lg:w-auto lg:justify-start"
        data-reveal="left"
        data-reveal-delay="0"
      >
        <!-- icon badge -->
        <div class="relative flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-gradient-to-br from-[#d8b15a]/20 to-[#d8b15a]/8 ring-1 ring-[#d8b15a]/30">
          <div class="absolute inset-0 rounded-2xl blur-sm bg-[#d8b15a]/10" aria-hidden="true"></div>
          <svg
            class="relative h-6 w-6 text-[#d8b15a]"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.8a19.79 19.79 0 01-3.07-8.67A2 2 0 012 .93h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L6.09 8.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/>
          </svg>
        </div>

        <div class="text-center lg:text-left">
          <p class="text-[12px] font-medium uppercase tracking-[0.18em] text-[#d8b15a]/80">
            {section.help.title}
          </p>
          <h2 class="mt-0.5 text-[22px] font-bold leading-tight text-white lg:text-[24px]">
            {section.help.subtitle}
          </h2>
        </div>
      </div>

      <!-- divider (desktop) -->
      <div class="hidden h-12 w-px shrink-0 bg-white/8 lg:block" aria-hidden="true"></div>

      <!-- STATS -->
      <div class="flex w-full flex-nowrap items-center justify-center gap-2 sm:gap-6 lg:flex-1 lg:gap-0">
        {
          section.stats.map((item, index) => (
            <div
              class="relative flex min-w-0 flex-1 flex-col items-center px-1 text-center sm:px-6 lg:flex-1"
              data-reveal="up"
              data-reveal-delay={String(200 + index * 180)}
            >
              {/* vertical divider between stats on desktop */}
              {index > 0 && (
                <div class="absolute inset-y-0 left-0 hidden w-px bg-white/8 lg:block" aria-hidden="true" />
              )}

              <span class="text-[22px] font-extrabold leading-none tracking-tight text-[#d8b15a] sm:text-[30px] lg:text-[34px]">
                {item.number}
              </span>

              <span class="mt-1 text-[9px] font-medium uppercase leading-tight tracking-[0.1em] text-white/50 sm:mt-1.5 sm:text-[12px] sm:tracking-[0.14em]">
                {item.label}
              </span>
            </div>
          ))
        }
      </div>

      <!-- divider (desktop) -->
      <div class="hidden h-12 w-px shrink-0 bg-white/8 lg:block" aria-hidden="true"></div>

      <!-- CTA BUTTON -->
      <a
        href={section.button.link}
        class="group relative mx-auto shrink-0 overflow-hidden rounded-2xl bg-gradient-to-br from-[#d8b15a] to-[#b8923e] px-7 py-4 text-[14px] font-bold uppercase tracking-[0.12em] text-[#1C1008] shadow-[0_8px_28px_rgba(216,177,90,0.30)] transition duration-300 hover:-translate-y-0.5 hover:shadow-[0_12px_36px_rgba(216,177,90,0.50)] lg:mx-0"
        data-reveal="right"
        data-reveal-delay="700"
      >
        <!-- shine sweep -->
        <span
          class="pointer-events-none absolute inset-0 -skew-x-12 -translate-x-full bg-white/15 transition-transform duration-500 group-hover:translate-x-[200%]"
          aria-hidden="true"
        ></span>

        <span class="relative flex items-center gap-2.5">
          <svg
            class="h-4 w-4"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M8 2v4M16 2v4M3 10h18M5 4h14a2 2 0 012 2v14a2 2 0 01-2 2H5a2 2 0 01-2-2V6a2 2 0 012-2z"/>
          </svg>
          {section.button.text}
        </span>
      </a>

    </div>
  </div>

</section>
