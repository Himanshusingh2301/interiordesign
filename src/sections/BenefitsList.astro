---
export interface Props {
  heading?: string;
  columns?: 2 | 3;
  items?: Array<{
    title: string;
    description: string;
  }>;
}

const DEFAULT_ITEMS: NonNullable<Props["items"]> = [
  {
    title: "Local Weather Knowledge",
    description:
      "We know how Hurricane Force Winds can damage weak outdoor fixtures. Our partners build systems that stay secure even during rough storms.",
  },
  {
    title: "Smart Home Integration",
    description:
      "You can control your entire yard from your phone with our smart systems. Our partners set up zoning so you can light up specific areas whenever you want.",
  },
  {
    title: "Marine-Grade Materials",
    description:
      "We refuse to use plastic or cheap aluminum that corrodes in the salty air. We use solid copper and brass that develop a beautiful patina over time.",
  },
  {
    title: "Expert Design Partners",
    description:
      "We don\u2019t just stick lights in the ground randomly. Our professional partners plan every angle to make your home look like a resort.",
  },
  {
    title: "Turtle-Safe Lighting",
    description:
      "Living near the ocean means we must protect nesting sea turtles. We use amber wavelengths that follow all local environmental rules.",
  },
  {
    title: "No-Hassle Warranty",
    description:
      "We stand behind the quality of our work and materials. If a fixture fails due to a defect, we make it right without stress for you.",
  },
];

const {
  heading = "Benefits Of Installing Outdoor Lighting",
  columns = 2,
  items = DEFAULT_ITEMS,
} = Astro.props;

const colClass: Record<number, string> = {
  2: "sm:grid-cols-2",
  3: "sm:grid-cols-2 lg:grid-cols-3",
};
---

<section class="bg-white">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-16 lg:py-24">
    <div class="mx-auto mb-12 max-w-3xl text-center">
      <h2
        class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight text-slate-900"
      >
        {heading}
      </h2>
      <div
        class="mx-auto mt-4 h-[2px] w-20 bg-slate-300"
        aria-hidden="true"
      >
      </div>
    </div>

    <div class={`grid grid-cols-1 ${colClass[columns]} gap-x-12 gap-y-10`}>
      {
        items.map((item) => (
          <article>
            <h3 class="flex items-baseline gap-2 text-xl sm:text-2xl font-bold text-slate-900">
              <span aria-hidden="true" class="text-slate-700">&raquo;</span>
              <span>{item.title}</span>
            </h3>
            <p class="mt-3 text-base leading-relaxed text-slate-600">
              {item.description}
            </p>
          </article>
        ))
      }
    </div>
  </div>
</section>
