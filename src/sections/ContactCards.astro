---
type ContactType = "phone" | "address" | "email";

export interface Props {
  heading?: string;
  items?: Array<{
    type: ContactType;
    label: string;
    value: string;
    /** Optional href override; otherwise auto-generated for phone/email. */
    href?: string;
  }>;
}

const DEFAULT_ITEMS: NonNullable<Props["items"]> = [
  { type: "phone", label: "Call Us", value: "(910) 218-9037" },
  { type: "address", label: "Address", value: "305 Raleigh St # E Wilmington, NC 28412" },
  { type: "email", label: "Email Us", value: "contact@outdoorlightingwilmington.com" },
];

const {
  heading = "Get In Touch",
  items = DEFAULT_ITEMS,
} = Astro.props;

const computeHref = (item: { type: ContactType; value: string; href?: string }) => {
  if (item.href) return item.href;
  if (item.type === "phone") return `tel:${item.value.replace(/[^\d+]/g, "")}`;
  if (item.type === "email") return `mailto:${item.value}`;
  return undefined;
};
---

<section id="contact" class="bg-white">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-16 lg:py-24">
    <div class="mx-auto mb-12 text-center">
      <h2
        class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight text-slate-900"
      >
        {heading}
      </h2>
      <div
        class="mx-auto mt-4 h-[2px] w-20 bg-slate-300"
        aria-hidden="true"
      >
      </div>
    </div>

    <address class="not-italic">
      <ul class="grid grid-cols-1 sm:grid-cols-3 gap-6 sm:gap-8">
        {
          items.map((item) => {
            const href = computeHref(item);

            const icon =
              item.type === "phone" ? (
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.6"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="h-7 w-7"
                  aria-hidden="true"
                >
                  <rect x="6" y="2.5" width="12" height="19" rx="2.5" />
                  <line x1="11" y1="18.5" x2="13" y2="18.5" />
                </svg>
              ) : item.type === "address" ? (
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.6"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="h-7 w-7"
                  aria-hidden="true"
                >
                  <polygon points="3,6 9,3 15,6 21,3 21,18 15,21 9,18 3,21" />
                  <line x1="9" y1="3" x2="9" y2="18" />
                  <line x1="15" y1="6" x2="15" y2="21" />
                </svg>
              ) : (
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.6"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="h-7 w-7"
                  aria-hidden="true"
                >
                  <rect x="3" y="5" width="18" height="14" rx="2" />
                  <polyline points="3,7 12,13 21,7" />
                </svg>
              );

            const cardInner = (
              <>
                <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full border border-slate-300 bg-white text-slate-700">
                  {icon}
                </div>
                <p class="mt-5 text-lg font-bold text-slate-900">{item.label}</p>
                <p class="mt-2 text-sm text-slate-600 break-words">
                  {item.value}
                </p>
              </>
            );

            return (
              <li class="rounded-lg bg-slate-50 px-6 py-8 text-center transition-shadow hover:shadow-md">
                {href ? (
                  <a
                    href={href}
                    class="block rounded-lg focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-slate-400"
                  >
                    {cardInner}
                  </a>
                ) : (
                  <div>{cardInner}</div>
                )}
              </li>
            );
          })
        }
      </ul>
    </address>
  </div>
</section>
