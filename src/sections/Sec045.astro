---
import { sec045ContentSchema } from "../content/schemas";
import sec045Data from "../data/sec045.json";

const content = sec045ContentSchema.parse(sec045Data);
const section = content.modernInteriorHero;


const callAriaLabel = `${section.callButton.label} for interior design consultation in Indore`;
const whatsappAriaLabel = `Contact interior designers in Indore on WhatsApp at ${section.business.telephone}`;
---

<section
  class="overflow-hidden bg-[#F5EFE6]"
  style="min-height: calc(100svh - var(--navbar-h, 72px)); display: flex; align-items: center;"
  aria-labelledby="sec045-hero-heading"
>
  <div class="mx-auto w-[92%] max-w-[1350px] py-8 lg:py-10">

    <div class="grid items-stretch gap-8 lg:grid-cols-[0.95fr_1.05fr] lg:gap-10">

      <!-- Left column -->
      <div class="flex flex-col justify-center">

        <!-- 1. Heading -->
        <h1
          id="sec045-hero-heading"
          class="max-w-[580px] text-[26px] font-semibold leading-[1.15] text-[#1C1008] sm:text-[32px] lg:text-[38px]"
          style="font-family: 'Cormorant Garamond', serif;"
          data-reveal="up"
          data-reveal-delay="0"
        >
          {section.heading}
        </h1>

        <!-- 2. Description -->
        <div
          class="mt-3 max-w-[580px] space-y-3 text-[14px] leading-[1.75] text-[#4A3525] lg:space-y-3.5 lg:text-[15px]"
          data-reveal="up"
          data-reveal-delay="280"
        >
          {
            Array.isArray(section.description)
              ? section.description.map((line) => <p>{line}</p>)
              : <p>{section.description}</p>
          }
        </div>

        <!-- 3. MOBILE IMAGES — hidden on lg+ (desktop uses the absolute-positioned right column) -->
        <figure
          class="order-2 mt-5 flex gap-2.5 lg:hidden"
          data-reveal="up"
          data-reveal-delay="420"
        >
          <div class="overflow-hidden rounded-[16px] shadow-[0_12px_32px_rgba(0,0,0,0.14)]" style="flex: 1.15; min-width: 0; aspect-ratio: 3/4;">
            <img
              src={section.images.main.src}
              alt={section.images.main.alt}
              width="800"
              height="960"
              fetchpriority="high"
              loading="eager"
              decoding="async"
              class="h-full w-full object-cover"
            />
          </div>
          <div class="flex flex-col gap-2.5" style="flex: 0.85; min-width: 0;">
            <div class="min-h-0 flex-1 overflow-hidden rounded-[16px] shadow-[0_8px_24px_rgba(0,0,0,0.11)]">
              <img src={section.images.lamp.src} alt={section.images.lamp.alt} width="600" height="480" loading="lazy" decoding="async" class="h-full w-full object-cover" />
            </div>
            <div class="min-h-0 flex-1 overflow-hidden rounded-[16px] shadow-[0_8px_24px_rgba(0,0,0,0.11)]">
              <img src={section.images.chair.src} alt={section.images.chair.alt} width="600" height="480" loading="lazy" decoding="async" class="h-full w-full object-cover" />
            </div>
          </div>
        </figure>

        <!-- 4. BUTTONS — one row, each takes equal width on mobile -->
        <nav
          class="order-1 mt-5 flex items-center gap-2.5 lg:gap-3"
          aria-label="Book interior design consultation"
          data-reveal="up"
          data-reveal-delay="560"
        >

          <a
            href={section.callButton.href}
            class="flex flex-1 items-center justify-center gap-2 rounded-xl bg-[#d8b15a] px-4 py-3 text-[13.5px] font-semibold text-[#1f2d2d] transition duration-300 hover:scale-105 hover:bg-[#e8c56a] lg:flex-none lg:px-6 lg:text-[15px]"
            aria-label={callAriaLabel}
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4 shrink-0" aria-hidden="true">
              <path fill-rule="evenodd" d="M2 3.5A1.5 1.5 0 0 1 3.5 2h1.148a1.5 1.5 0 0 1 1.465 1.175l.716 3.223a1.5 1.5 0 0 1-.43 1.402L5.27 8.962a11.04 11.04 0 0 0 5.768 5.769l1.162-1.13a1.5 1.5 0 0 1 1.402-.43l3.223.716A1.5 1.5 0 0 1 18 15.352V16.5a1.5 1.5 0 0 1-1.5 1.5H15c-7.18 0-13-5.82-13-13V3.5Z" clip-rule="evenodd" />
            </svg>
            <span class="lg:hidden">Free Site Visit</span>
            <span class="hidden lg:inline">{section.callButton.label}</span>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4 shrink-0" aria-hidden="true">
              <path fill-rule="evenodd" d="M3 10a.75.75 0 0 1 .75-.75h10.638L10.23 5.29a.75.75 0 1 1 1.04-1.08l5.5 5.25a.75.75 0 0 1 0 1.08l-5.5 5.25a.75.75 0 1 1-1.04-1.08l4.138-3.96H3.75A.75.75 0 0 1 3 10Z" clip-rule="evenodd" />
            </svg>
          </a>

          <a
            href={section.whatsapp.href}
            class="flex flex-1 items-center justify-center gap-2 rounded-xl border border-[#25D366]/40 bg-[#25D366]/10 px-4 py-3 text-[13.5px] font-medium text-[#1a7a40] transition duration-300 hover:border-[#25D366]/70 hover:bg-[#25D366]/20 lg:flex-none lg:px-6 lg:text-[14px]"
            target="_blank"
            rel="noopener noreferrer"
            aria-label={whatsappAriaLabel}
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4 shrink-0" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
            </svg>
            <span class="lg:hidden">Chat Now</span>
            <span class="hidden lg:inline">{section.whatsapp.label}</span>
          </a>

        </nav>

        <!-- Trust badges -->
        <div
          class="order-3 mt-4 flex items-center justify-center gap-x-2 lg:justify-start lg:gap-x-4"
          data-reveal="up"
          data-reveal-delay="720"
          aria-label="Our service guarantees"
        >

          <span class="flex shrink-0 items-center gap-1 whitespace-nowrap text-[10.5px] font-medium text-[#4A3525] sm:gap-1.5 sm:text-[12px]">
            <svg class="h-3 w-3 shrink-0 text-[#d8b15a] sm:h-3.5 sm:w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
            </svg>
            Free Site Visit
          </span>

          <span class="shrink-0 text-[10px] text-[#1C1008]/25" aria-hidden="true">|</span>

          <span class="flex shrink-0 items-center gap-1 whitespace-nowrap text-[10.5px] font-medium text-[#4A3525] sm:gap-1.5 sm:text-[12px]">
            <svg class="h-3 w-3 shrink-0 text-[#d8b15a] sm:h-3.5 sm:w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/>
            </svg>
            Transparent Pricing
          </span>

          <span class="shrink-0 text-[10px] text-[#1C1008]/25" aria-hidden="true">|</span>

          <span class="flex shrink-0 items-center gap-1 whitespace-nowrap text-[10.5px] font-medium text-[#4A3525] sm:gap-1.5 sm:text-[12px]">
            <svg class="h-3 w-3 shrink-0 text-[#d8b15a] sm:h-3.5 sm:w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/>
            </svg>
            1-Year Warranty
          </span>

        </div>

      </div>

      <!-- Desktop-only right image column -->
      <div class="relative hidden lg:block">
        <figure
          class="absolute inset-0 flex gap-3"
          data-reveal="right"
          data-reveal-delay="400"
        >
          <div class="overflow-hidden rounded-[22px] shadow-[0_20px_56px_rgba(0,0,0,0.16)]" style="flex: 1.15; min-width: 0;">
            <img
              src={section.images.main.src}
              alt={section.images.main.alt}
              width="800"
              height="960"
              fetchpriority="high"
              loading="eager"
              decoding="async"
              class="h-full w-full object-cover transition duration-700 hover:scale-105"
            />
          </div>
          <div class="flex flex-col gap-3" style="flex: 0.85; min-width: 0;">
            <div class="min-h-0 flex-1 overflow-hidden rounded-[22px] shadow-[0_12px_40px_rgba(0,0,0,0.13)]">
              <img src={section.images.lamp.src} alt={section.images.lamp.alt} width="600" height="480" loading="lazy" decoding="async" class="h-full w-full object-cover transition duration-700 hover:scale-105" />
            </div>
            <div class="min-h-0 flex-1 overflow-hidden rounded-[22px] shadow-[0_12px_40px_rgba(0,0,0,0.13)]">
              <img src={section.images.chair.src} alt={section.images.chair.alt} width="600" height="480" loading="lazy" decoding="async" class="h-full w-full object-cover transition duration-700 hover:scale-105" />
            </div>
          </div>
        </figure>
      </div>

    </div>

  </div>

</section>
