---
export interface Props {
  heading?: string;
  items?: Array<{ question: string; answer: string }>;
  /** Index of item open by default */
  defaultOpenIndex?: number;
}

const DEFAULT_ITEMS: NonNullable<Props["items"]> = [
  {
    question: "How much does a lighting system cost?",
    answer:
      "Most average systems range between $2,500 and $4,500 depending on the size. This includes all marine-grade fixtures, installation, and cleanup.",
  },
  {
    question: "Will outdoor lights increase my electric bill?",
    answer:
      "We use efficient Low-Voltage LED technology that consumes very little power. You will likely see only a tiny increase in your monthly bill.",
  },
  {
    question: "Is your lighting safe for sea turtles?",
    answer:
      "Absolutely, especially for homes near the beach. We use amber lights and shields to ensure we meet all local wildlife rules.",
  },
  {
    question: "Are your lights waterproof?",
    answer:
      "Yes, our partners use fixtures with an IP68 Waterproof Rating. They can handle heavy rain and even temporary flooding without failing.",
  },
  {
    question: "Do you offer a warranty?",
    answer:
      "Yes, we offer strong warranties on both the fixtures and the bulbs. If something breaks due to a defect, we fix it.",
  },
  {
    question: "Do you repair existing systems?",
    answer:
      "Yes, our partners can fix systems installed by other companies. We can also upgrade your old lights to new LEDs.",
  },
];

const {
  heading = "Frequently Asked Questions",
  items = DEFAULT_ITEMS,
  defaultOpenIndex = 0,
} = Astro.props;
---

<section class="relative overflow-hidden bg-slate-50 py-16 lg:py-24">
  <!-- Background Glow -->
  <div
    class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_top,rgba(15,23,42,0.05),transparent_50%)]"
    aria-hidden="true"
  ></div>

  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="mx-auto mb-12 text-center">
      

      <h2
        class="mt-5 text-3xl font-black tracking-tight text-slate-900 sm:text-4xl lg:text-5xl"
      >
        {heading}
      </h2>

      <div
        class="mx-auto mt-6 h-1.5 w-24 rounded-full bg-slate-900"
        aria-hidden="true"
      ></div>
    </div>

    <!-- FAQ -->
    <div class="space-y-4">
      {
        items.map((item, index) => (
          <details
            class="faq-item group rounded-2xl border border-slate-200 bg-white shadow-sm"
            open={index === defaultOpenIndex}
          >
            <summary
              class="faq-summary flex cursor-pointer items-center justify-between gap-5 px-5 py-5 sm:px-7 sm:py-6"
            >
              <div class="flex items-start gap-4">
                <div
                  class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full border border-slate-200 bg-slate-100 text-sm font-bold text-slate-700 transition-all duration-300 group-open:border-slate-900 group-open:bg-slate-900 group-open:text-white"
                >
                  {(index + 1).toString().padStart(2, "0")}
                </div>

                <span
                  class="text-left text-base font-bold leading-snug text-slate-900 sm:text-lg"
                >
                  {item.question}
                </span>
              </div>

              <div
                class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full border border-slate-200 bg-slate-100"
              >
                <svg
                  class="faq-icon h-5 w-5 text-slate-700"
                  viewBox="0 0 20 20"
                  fill="currentColor"
                  aria-hidden="true"
                >
                  <path
                    fill-rule="evenodd"
                    d="M5.23 7.21a.75.75 0 011.06.02L10 11.06l3.71-3.83a.75.75 0 111.08 1.04l-4.25 4.39a.75.75 0 01-1.08 0L5.21 8.27a.75.75 0 01.02-1.06z"
                    clip-rule="evenodd"
                  />
                </svg>
              </div>
            </summary>

            <div class="faq-content">
              <div class="border-t border-slate-100 px-5 pb-6 pt-5 sm:px-7 sm:pb-7">
                <p
                  class="faq-text text-sm leading-relaxed text-slate-600 sm:text-base"
                >
                  {item.answer}
                </p>
              </div>
            </div>
          </details>
        ))
      }
    </div>
  </div>

</section>

<style>
  .faq-summary::-webkit-details-marker {
    display: none;
  }

  .faq-summary {
    list-style: none;
  }

  /* FAQ Card */
  .faq-item {
    overflow: hidden;
    transition:
      border-color 0.3s ease,
      box-shadow 0.3s ease,
      transform 0.3s ease;
  }

  .faq-item:hover {
    transform: translateY(-2px);
    box-shadow: 0 20px 45px rgba(15, 23, 42, 0.08);
  }

  .faq-item[open] {
    border-color: rgba(15, 23, 42, 0.12);
    box-shadow: 0 18px 40px rgba(15, 23, 42, 0.08);
  }

  /* Smooth Accordion */
  .faq-content {
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    transform: translateY(-8px);
    transition:
      max-height 0.65s cubic-bezier(0.22, 1, 0.36, 1),
      opacity 0.4s ease,
      transform 0.4s ease;
  }

  .faq-item[open] .faq-content {
    max-height: 500px;
    opacity: 1;
    transform: translateY(0);
  }

  /* Text Animation */
  .faq-text {
    opacity: 0;
    transform: translateY(10px);
    transition:
      opacity 0.45s ease 0.12s,
      transform 0.45s ease 0.12s;
  }

  .faq-item[open] .faq-text {
    opacity: 1;
    transform: translateY(0);
  }

  /* Icon Rotation */
  .faq-icon {
    transition: transform 0.45s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .faq-item[open] .faq-icon {
    transform: rotate(180deg);
  }

  /* Better smoothness */
  .faq-item,
  .faq-content,
  .faq-icon {
    will-change: transform;
  }

  /* Accessibility */
  @media (prefers-reduced-motion: reduce) {
    .faq-item,
    .faq-content,
    .faq-icon,
    .faq-text {
      transition: none !important;
    }
  }
</style>