# Copy to `.env` for local development (optional).

# Production site URL — no trailing path. Overrides `SITE_URL_FALLBACK` in
# `src/site.config.ts` for canonicals, sitemap, robots, and JSON-LD.
# Set the same variable on Vercel (Production) so deploys always match the hostname.
# PUBLIC_SITE_URL=https://atlantaleakdetection02.vercel.app

# Allow Google to index this build (default if unset).
PUBLIC_ALLOW_INDEXING=true

# Google Search Console (HTML tag method) — paste only the `content` value from
# the meta tag Google shows you, not the full tag.
# PUBLIC_GOOGLE_SITE_VERIFICATION=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI (optional — only for `npm run content:ai`)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4.1-mini
